# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# datos locales (sqlite + nominas)
data/

# script de deploy: contiene IP/usuario/dominio del VPS - fuera del repo
deploy.ps1

# Android (build artifacts; el proyecto vive en android/)
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/.idea/
*.apk
*.aab
